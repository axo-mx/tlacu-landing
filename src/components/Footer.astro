---
// Footer component
import PlatformLink from './PlatformLink.astro';
const currentYear = new Date().getFullYear();
---

<footer class="bg-navy text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {/* Main footer content */}
    <div class="py-12 lg:py-16 grid sm:grid-cols-2 lg:grid-cols-5 gap-8 lg:gap-10">
      {/* Brand column */}
      <div class="sm:col-span-2 lg:col-span-2">
        <a href="/" class="inline-block mb-4">
          <img
            src="/images/logos/logo-tlacu-light.webp"
            alt="TLACU"
            class="h-10 w-auto"
            width="122"
            height="40"
            loading="lazy"
          />
        </a>
        <p class="text-white/75 text-sm mb-6 max-w-sm">
          Plataforma educativa 100% responsiva que enciende el conocimiento.
          Como el tlacuache que trajo el fuego, llevamos el saber a todos.
        </p>
        <div class="flex gap-4 mb-6">
          <a href="https://www.facebook.com/profile.php?id=61583795336492" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-turquoise transition-colors" aria-label="Facebook">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/tlacumx/" target="_blank" rel="noopener noreferrer" class="w-10 h-10 bg-white/10 rounded-lg flex items-center justify-center hover:bg-turquoise transition-colors" aria-label="Instagram">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
            </svg>
          </a>
        </div>
        <div class="flex gap-3">
          <PlatformLink path="/autenticacion/registro" class="px-5 py-2 bg-terracotta-dark text-white text-sm font-semibold rounded-lg hover:bg-terracotta transition-colors">
            Registrarse gratis
          </PlatformLink>
          <PlatformLink path="/autenticacion/iniciar-sesion" class="px-5 py-2 bg-white/10 text-white text-sm font-semibold rounded-lg hover:bg-white/20 transition-colors">
            Iniciar sesión
          </PlatformLink>
        </div>
      </div>

      {/* Plataforma column */}
      <div>
        <h3 class="text-base font-bold mb-4">Plataforma</h4>
        <ul class="space-y-3">
          <li><a href="/plataforma" class="text-white/75 hover:text-turquoise transition-colors">Vista general</a></li>
          <li><a href="/plan-estudio" class="text-white/75 hover:text-turquoise transition-colors">Plan de estudio</a></li>
          <li><a href="/practicar-preguntas" class="text-white/75 hover:text-turquoise transition-colors">Practicar preguntas</a></li>
          <li><a href="/flashcards" class="text-white/75 hover:text-turquoise transition-colors">Flashcards</a></li>
          <li><a href="/repaso-espaciado" class="text-white/75 hover:text-turquoise transition-colors">Repetición espaciada</a></li>
          <li><a href="/modulos-interactivos" class="text-white/75 hover:text-turquoise transition-colors">Módulos interactivos</a></li>
          <li><a href="/modulos/refuerzo" class="text-white/75 hover:text-turquoise transition-colors">Módulos de refuerzo</a></li>
        </ul>
      </div>

      {/* Exámenes column */}
      <div>
        <h3 class="text-base font-bold mb-4">Exámenes</h4>
        <ul class="space-y-3">
          <li><a href="/examenes" class="text-white/75 hover:text-turquoise transition-colors">Todos los exámenes</a></li>
          <li><a href="/examenes/diagnostico" class="text-white/75 hover:text-turquoise transition-colors">Diagnóstico</a></li>
          <li><a href="/examenes/rapido" class="text-white/75 hover:text-turquoise transition-colors">Examen Rápido</a></li>
          <li><a href="/examenes/completo" class="text-white/75 hover:text-turquoise transition-colors">Examen Completo</a></li>
          <li><a href="/examenes/simulador" class="text-white/75 hover:text-turquoise transition-colors">Simulador con Cámara</a></li>
        </ul>

        <h3 class="text-base font-bold mb-4 mt-8">Precios</h4>
        <ul class="space-y-3">
          <li><a href="/precios" class="text-white/75 hover:text-turquoise transition-colors">Planes y precios</a></li>
        </ul>
      </div>

      {/* TLACU + Legal column */}
      <div>
        <h3 class="text-base font-bold mb-4">TLACU</h4>
        <ul class="space-y-3">
          <li><a href="/acerca" class="text-white/75 hover:text-turquoise transition-colors">Acerca de</a></li>
          <li><a href="/que-es-ecoems" class="text-white/75 hover:text-turquoise transition-colors">¿Qué es el ECOEMS?</a></li>
          <li><a href="/por-que-tlacu" class="text-white/75 hover:text-turquoise transition-colors">¿Por qué TLACU?</a></li>
          <li><a href="/para-padres" class="text-white/75 hover:text-turquoise transition-colors">Para Padres y Tutores</a></li>
          <li><a href="/hoja-de-ruta" class="text-white/75 hover:text-turquoise transition-colors">Hoja de ruta</a></li>
          <li><a href="/contacto" class="text-white/75 hover:text-turquoise transition-colors">Contacto</a></li>
        </ul>

        <h3 class="text-base font-bold mb-4 mt-8">Legal</h4>
        <ul class="space-y-3">
          <li><a href="/terminos" class="text-white/75 hover:text-turquoise transition-colors">Términos de servicio</a></li>
          <li><a href="/privacidad" class="text-white/75 hover:text-turquoise transition-colors">Política de privacidad</a></li>
        </ul>
      </div>
    </div>

    {/* Bottom bar */}
    <div class="py-6 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/60 text-sm">
        &copy; {currentYear} TLACU. Todos los derechos reservados.
      </p>
      <p class="text-white/60 text-sm flex items-center gap-2">
        Hecho con
        <svg class="w-4 h-4 text-terracotta" fill="currentColor" viewBox="0 0 24 24">
          <path d="M17.66 11.2C17.43 10.9 17.16 10.64 16.85 10.43C16.1 9.89 15.57 9.07 15.39 8.14C15.24 7.37 14.86 6.64 14.29 6.05C13.35 5.09 12 4 12 4C12 4 10.65 5.09 9.71 6.05C9.14 6.64 8.76 7.37 8.61 8.14C8.43 9.07 7.9 9.89 7.15 10.43C6.84 10.64 6.57 10.9 6.34 11.2C5.45 12.39 5 13.81 5 15.25C5 19.04 8.13 22 12 22C15.87 22 19 19.04 19 15.25C19 13.81 18.55 12.39 17.66 11.2Z"></path>
        </svg>
        en México
      </p>
    </div>
  </div>
</footer>
