---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// Razones de contacto
const contactReasons = [
  { value: 'general', label: 'Pregunta general' },
  { value: 'support', label: 'Soporte técnico' },
  { value: 'partnership', label: 'Alianzas y colaboraciones' },
  { value: 'feedback', label: 'Sugerencias y comentarios' },
  { value: 'schools', label: 'Escuelas e instituciones' },
];

// FAQs rápidas
const quickFaqs = [
  {
    question: '¿Cómo recupero mi contraseña?',
    answer: 'Ve a la página de inicio de sesión y haz clic en "¿Olvidaste tu contraseña?". Te enviaremos un correo con instrucciones.',
  },
  {
    question: '¿Puedo cambiar de plan Gratuito a Pro?',
    answer: 'Sí, puedes actualizar en cualquier momento desde tu perfil. Tu progreso se mantiene intacto.',
  },
  {
    question: '¿Desde qué dispositivos puedo acceder?',
    answer: 'TLACU es 100% responsivo. Funciona perfectamente en computadora, tablet y celular desde tu navegador.',
  },
];

const seoTitle = 'Contacto — ¿Dudas sobre TLACU o el ECOEMS? | TLACU';
const seoDescription = '¿Tienes dudas sobre TLACU o el ECOEMS? Contáctanos por correo o redes sociales. Soporte técnico, alianzas y sugerencias.';
const canonicalUrl = 'https://tlacu.mx/contacto';
---

<Layout title={seoTitle} description={seoDescription} ogImage="/images/og/og-contacto.png">
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": seoTitle,
      "description": seoDescription,
      "url": canonicalUrl,
      "inLanguage": "es-MX",
      "isPartOf": { "@type": "WebSite", "name": "TLACU — Prepárate, enciende tu futuro", "url": "https://tlacu.mx/" }
    })} />
  </Fragment>
  <Header />

  <main>
    <!-- Hero -->
    <section class="pt-36 sm:pt-40 pb-16 bg-gradient-hero">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-3xl mx-auto">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-turquoise/20 rounded-full text-turquoise text-sm font-medium mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            Estamos para ayudarte
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
            <span class="text-gradient-fire">Contáctanos</span>
          </h1>
          <p class="text-xl text-white/70">
            ¿Tienes dudas, sugerencias o necesitas ayuda? Escríbenos y te responderemos lo antes posible.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Methods + Form -->
    <section class="py-20 bg-cream">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-5 gap-12">

          <!-- Contact Info Column -->
          <div class="lg:col-span-2 space-y-8">
            <div>
              <h2 class="text-2xl font-bold text-navy mb-6">Información de contacto</h2>
              <p class="text-navy/60 mb-8">
                Elige el método que prefieras. Respondemos en menos de 24 horas en días hábiles.
              </p>
            </div>

            <!-- Email -->
            <a href="mailto:hola@tlacu.mx" class="flex items-start gap-4 p-5 bg-white rounded-2xl shadow-md border border-navy/5 hover:border-turquoise/30 hover:shadow-lg transition-all group">
              <div class="w-12 h-12 bg-turquoise/10 rounded-xl flex items-center justify-center group-hover:bg-turquoise transition-colors">
                <svg class="w-6 h-6 text-turquoise group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <div class="font-bold text-navy group-hover:text-turquoise transition-colors">Correo electrónico</div>
                <div class="text-navy/60 text-sm">Para consultas detalladas</div>
                <div class="text-turquoise font-medium mt-1">hola@tlacu.mx</div>
              </div>
            </a>

            <!-- Support Email -->
            <a href="mailto:soporte@tlacu.mx" class="flex items-start gap-4 p-5 bg-white rounded-2xl shadow-md border border-navy/5 hover:border-turquoise/30 hover:shadow-lg transition-all group">
              <div class="w-12 h-12 bg-terracotta/10 rounded-xl flex items-center justify-center group-hover:bg-terracotta transition-colors">
                <svg class="w-6 h-6 text-terracotta group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
                </svg>
              </div>
              <div>
                <div class="font-bold text-navy group-hover:text-terracotta transition-colors">Soporte técnico</div>
                <div class="text-navy/60 text-sm">Problemas con tu cuenta</div>
                <div class="text-terracotta font-medium mt-1">soporte@tlacu.mx</div>
              </div>
            </a>

            <!-- Social Media -->
            <div class="pt-4">
              <h3 class="font-bold text-navy mb-4">Síguenos en redes</h3>
              <div class="flex gap-3">
                <a href="https://www.facebook.com/tlacumx" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-white rounded-xl shadow-md border border-navy/5 flex items-center justify-center hover:bg-turquoise hover:text-white hover:border-turquoise transition-all text-navy/60" aria-label="Facebook">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                  </svg>
                </a>
                <a href="https://www.instagram.com/tlacumx/" target="_blank" rel="noopener noreferrer" class="w-12 h-12 bg-white rounded-xl shadow-md border border-navy/5 flex items-center justify-center hover:bg-gradient-to-tr hover:from-purple-600 hover:to-pink-500 hover:text-white hover:border-transparent transition-all text-navy/60" aria-label="Instagram">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
                  </svg>
                </a>
              </div>
            </div>

            <!-- Response time badge -->
            <div class="flex items-center gap-3 p-4 bg-turquoise/10 rounded-xl">
              <svg class="w-6 h-6 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <div>
                <div class="font-semibold text-navy text-sm">Tiempo de respuesta</div>
                <div class="text-navy/60 text-sm">Menos de 24 horas en días hábiles</div>
              </div>
            </div>
          </div>

          <!-- Contact Form Column -->
          <div class="lg:col-span-3">
            <div class="bg-white rounded-3xl shadow-xl border border-navy/5 p-8 lg:p-10">
              <h2 class="text-2xl font-bold text-navy mb-2">Envíanos un mensaje</h2>
              <p class="text-navy/60 mb-8">Completa el formulario y te responderemos pronto.</p>

              <form id="contact-form" class="space-y-6">
                <!-- Honeypot — invisible to humans, bots fill it -->
                <div style="position:absolute;left:-9999px;" aria-hidden="true">
                  <label for="_hp">No completar</label>
                  <input type="text" id="_hp" name="_hp" tabindex="-1" autocomplete="off" />
                </div>
                <!-- Time token — set by JS on load -->
                <input type="hidden" id="_t" name="_t" value="" />

                <div class="grid sm:grid-cols-2 gap-6">
                  <!-- Name -->
                  <div>
                    <label for="name" class="block text-sm font-semibold text-navy mb-2">Nombre completo *</label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      placeholder="Tu nombre"
                      class="w-full px-4 py-3 bg-cream border border-navy/10 rounded-xl text-navy placeholder:text-navy/40 focus:outline-none focus:ring-2 focus:ring-turquoise focus:border-transparent transition-all"
                    />
                  </div>

                  <!-- Email -->
                  <div>
                    <label for="email" class="block text-sm font-semibold text-navy mb-2">Correo electrónico *</label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      placeholder="tu@email.com"
                      class="w-full px-4 py-3 bg-cream border border-navy/10 rounded-xl text-navy placeholder:text-navy/40 focus:outline-none focus:ring-2 focus:ring-turquoise focus:border-transparent transition-all"
                    />
                  </div>
                </div>

                <!-- Reason -->
                <div>
                  <label for="reason" class="block text-sm font-semibold text-navy mb-2">Motivo de contacto *</label>
                  <select
                    id="reason"
                    name="reason"
                    required
                    class="w-full px-4 py-3 bg-cream border border-navy/10 rounded-xl text-navy focus:outline-none focus:ring-2 focus:ring-turquoise focus:border-transparent transition-all appearance-none cursor-pointer"
                  >
                    <option value="" disabled selected>Selecciona una opción</option>
                    {contactReasons.map(reason => (
                      <option value={reason.value}>{reason.label}</option>
                    ))}
                  </select>
                </div>

                <!-- Subject -->
                <div>
                  <label for="subject" class="block text-sm font-semibold text-navy mb-2">Asunto *</label>
                  <input
                    type="text"
                    id="subject"
                    name="subject"
                    required
                    placeholder="¿De qué quieres hablar?"
                    class="w-full px-4 py-3 bg-cream border border-navy/10 rounded-xl text-navy placeholder:text-navy/40 focus:outline-none focus:ring-2 focus:ring-turquoise focus:border-transparent transition-all"
                  />
                </div>

                <!-- Message -->
                <div>
                  <label for="message" class="block text-sm font-semibold text-navy mb-2">Mensaje *</label>
                  <textarea
                    id="message"
                    name="message"
                    required
                    rows="5"
                    placeholder="Escribe tu mensaje aquí..."
                    class="w-full px-4 py-3 bg-cream border border-navy/10 rounded-xl text-navy placeholder:text-navy/40 focus:outline-none focus:ring-2 focus:ring-turquoise focus:border-transparent transition-all resize-none"
                  ></textarea>
                </div>

                <!-- Error message -->
                <div id="form-error" class="hidden p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm"></div>

                <!-- Submit Button -->
                <button
                  type="submit"
                  id="submit-btn"
                  class="w-full px-6 py-4 bg-terracotta text-white font-bold rounded-xl hover:bg-terracotta-dark transition-colors shadow-lg shadow-terracotta/25 flex items-center justify-center gap-2"
                >
                  <span id="submit-text">Enviar mensaje</span>
                  <svg id="submit-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                  </svg>
                  <svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                </button>

                <p class="text-center text-sm text-navy/50">
                  Al enviar, aceptas nuestra <a href="/privacidad" class="text-turquoise hover:underline">política de privacidad</a>.
                </p>
              </form>

              <!-- Success message (hidden by default) -->
              <div id="success-message" class="hidden text-center py-12">
                <div class="w-20 h-20 bg-turquoise/10 rounded-full flex items-center justify-center mx-auto mb-6">
                  <svg class="w-10 h-10 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                </div>
                <h3 class="text-2xl font-bold text-navy mb-2">¡Mensaje enviado!</h3>
                <p class="text-navy/60 mb-6">Te responderemos pronto a tu correo electrónico.</p>
                <button id="reset-form" class="px-6 py-3 bg-navy/10 text-navy font-semibold rounded-xl hover:bg-navy/20 transition-colors">
                  Enviar otro mensaje
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick FAQs -->
    <section class="py-20 bg-cream-dark">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-black text-navy mb-4">
            Preguntas rápidas
          </h2>
          <p class="text-navy/60">
            Quizás tu duda ya tiene respuesta
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          {quickFaqs.map(faq => (
            <div class="bg-white rounded-2xl p-6 shadow-md border border-navy/5">
              <h3 class="font-bold text-navy mb-2 flex items-start gap-3">
                <svg class="w-5 h-5 text-turquoise mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                {faq.question}
              </h3>
              <p class="text-navy/60 text-sm pl-8">{faq.answer}</p>
            </div>
          ))}
        </div>

        <div class="text-center mt-10">
          <a href="/precios#faq" class="inline-flex items-center gap-2 text-turquoise font-semibold hover:text-turquoise-dark transition-colors">
            Ver todas las preguntas frecuentes
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Schools / Institutions CTA -->
    <section class="py-20 bg-gradient-to-br from-navy to-navy-light">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-4 py-2 bg-turquoise/20 rounded-full text-turquoise text-sm font-medium mb-6">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
              </svg>
              Para padres y profesores
            </div>
            <h2 class="text-3xl sm:text-4xl font-black text-white mb-6">
              ¿Eres padre de familia o profesor?
            </h2>
            <p class="text-white/70 mb-8">
              Regístrate como tutor y gestiona las cuentas de tus alumnos o hijos desde un solo lugar. Puedes dar de alta alumnos sin necesidad de que tengan correo electrónico.
            </p>
            <ul class="space-y-3 mb-8">
              <li class="flex items-center gap-3 text-white/80">
                <svg class="w-5 h-5 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Da de alta alumnos con nombre de usuario y contraseña
              </li>
              <li class="flex items-center gap-3 text-white/80">
                <svg class="w-5 h-5 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Panel con métricas de avance por alumno
              </li>
              <li class="flex items-center gap-3 text-white/80">
                <svg class="w-5 h-5 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Administra contraseñas de tus alumnos
              </li>
              <li class="flex items-center gap-3 text-white/80">
                <svg class="w-5 h-5 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Paga el Plan Pro de algunos o todos tus alumnos
              </li>
            </ul>
            <a
              href="/para-padres"
              class="inline-flex items-center gap-2 px-8 py-4 bg-turquoise text-navy font-bold rounded-xl hover:bg-turquoise-light transition-colors shadow-lg"
            >
              Conoce más
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
              </svg>
            </a>
          </div>

          <!-- Illustration -->
          <div class="hidden md:flex justify-center">
            <div class="relative">
              <div class="w-64 h-64 bg-turquoise/10 rounded-full absolute -top-8 -left-8 blur-3xl"></div>
              <div class="w-48 h-48 bg-terracotta/10 rounded-full absolute -bottom-4 -right-4 blur-3xl"></div>
              <div class="relative bg-white/10 backdrop-blur rounded-3xl p-8 border border-white/20">
                <div class="flex items-center gap-4 mb-6">
                  <div class="w-16 h-16 bg-turquoise/20 rounded-2xl flex items-center justify-center">
                    <svg class="w-8 h-8 text-turquoise" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-white font-bold">Panel de Tutor</div>
                    <div class="text-white/60 text-sm">Progreso de tus alumnos</div>
                  </div>
                </div>
                <div class="space-y-3">
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-white/70">María G.</span>
                    <span class="text-turquoise font-medium">78%</span>
                  </div>
                  <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                    <div class="h-full bg-turquoise rounded-full" style="width: 78%"></div>
                  </div>
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-white/70">Carlos R.</span>
                    <span class="text-turquoise font-medium">65%</span>
                  </div>
                  <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                    <div class="h-full bg-turquoise rounded-full" style="width: 65%"></div>
                  </div>
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-white/70">Ana L.</span>
                    <span class="text-turquoise font-medium">82%</span>
                  </div>
                  <div class="h-2 bg-white/10 rounded-full overflow-hidden">
                    <div class="h-full bg-turquoise rounded-full" style="width: 82%"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('success-message');
  const resetButton = document.getElementById('reset-form');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text');
  const submitIcon = document.getElementById('submit-icon');
  const submitSpinner = document.getElementById('submit-spinner');
  const formError = document.getElementById('form-error');
  const timeField = document.getElementById('_t') as HTMLInputElement;

  // PostHog helper
  function track(event: string, props?: Record<string, unknown>) {
    if (typeof window !== 'undefined' && (window as any).posthog?.capture) {
      (window as any).posthog.capture(event, props);
    }
  }

  // Set time token on page load (anti-bot)
  const formLoadTime = Date.now();
  if (timeField) timeField.value = String(formLoadTime);

  // Track page view
  track('contact_page_viewed');

  function setLoading(loading: boolean) {
    if (submitBtn) submitBtn.disabled = loading;
    submitText?.classList.toggle('hidden', loading);
    submitIcon?.classList.toggle('hidden', loading);
    submitSpinner?.classList.toggle('hidden', !loading);
    if (loading && submitBtn) {
      submitBtn.insertAdjacentHTML('afterbegin', '<span id="submit-loading-text">Enviando...</span>');
    } else {
      document.getElementById('submit-loading-text')?.remove();
    }
  }

  function showError(msg: string) {
    if (formError) {
      formError.textContent = msg;
      formError.classList.remove('hidden');
      formError.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  function hideError() {
    formError?.classList.add('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const formData = new FormData(form);
    const reason = formData.get('reason') as string;
    const data = {
      name: formData.get('name'),
      email: formData.get('email'),
      reason,
      subject: formData.get('subject'),
      message: formData.get('message'),
      _hp: formData.get('_hp'),
      _t: formData.get('_t'),
    };

    const timeOnForm = Math.round((Date.now() - formLoadTime) / 1000);

    track('contact_form_submitted', {
      reason,
      time_on_form_seconds: timeOnForm,
    });

    setLoading(true);

    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (!res.ok) {
        const errorType = res.status === 429 ? 'rate_limited' : 'server_error';
        showError(result.error || 'Hubo un error al enviar el mensaje. Intenta de nuevo.');
        track('contact_form_error', {
          reason,
          error_type: errorType,
          status_code: res.status,
        });
        return;
      }

      // Success
      form.classList.add('hidden');
      successMessage?.classList.remove('hidden');
      track('contact_form_success', {
        reason,
        time_on_form_seconds: timeOnForm,
      });
    } catch {
      showError('Error de conexión. Verifica tu internet e intenta de nuevo.');
      track('contact_form_error', {
        reason,
        error_type: 'network_error',
      });
    } finally {
      setLoading(false);
    }
  });

  resetButton?.addEventListener('click', () => {
    form.reset();
    if (timeField) timeField.value = String(Date.now());
    form.classList.remove('hidden');
    successMessage?.classList.add('hidden');
    hideError();
    track('contact_form_reset');
  });
</script>
