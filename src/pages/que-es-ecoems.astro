                  <div class={`w-3 h-3 rounded-full ${i === 3 ? 'bg-terracotta' : 'bg-turquoise'} shrink-0 mt-1.5`}></div>
                  {i < fechas.length - 1 && <div class="w-px h-8 bg-white/20"></div>}
                </div>
                <div class="pb-2">
                  <div class="text-white font-semibold text-sm">{f.title}</div>
                  <div class="text-white/50 text-xs">{f.description}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
