---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PlatformLink from '../components/PlatformLink.astro';
import { BookOpen, Binary, Languages, Calculator, Dna, Atom, FlaskConical, Clock, Globe2, Scale } from '@lucide/astro';

// 10 Áreas del ECOEMS
const areas = [
  { name: 'Habilidad Verbal', questions: 16, description: 'Comprensión lectora, inferencias, ideas principales y argumentación', color: 'bg-sky-500' },
  { name: 'Habilidad Matemática', questions: 16, description: 'Razonamiento lógico, secuencias, analogías y resolución de problemas', color: 'bg-orange-400' },
  { name: 'Español', questions: 12, description: 'Gramática, ortografía, sintaxis y uso correcto del español', color: 'bg-blue-500' },
  { name: 'Matemáticas', questions: 12, description: 'Aritmética, álgebra, geometría, estadística y probabilidad', color: 'bg-orange-500' },
  { name: 'Biología', questions: 12, description: 'Célula, genética, ecosistemas, cuerpo humano y evolución', color: 'bg-lime-500' },
  { name: 'Física', questions: 12, description: 'Movimiento, energía, ondas, electricidad y óptica', color: 'bg-slate-500' },
  { name: 'Química', questions: 12, description: 'Tabla periódica, reacciones, estados de la materia y enlaces', color: 'bg-fuchsia-500' },
  { name: 'Historia', questions: 12, description: 'México prehispánico, colonial, independencia y moderno', color: 'bg-amber-700' },
  { name: 'Geografía', questions: 12, description: 'Relieve, climas, regiones, población y recursos de México', color: 'bg-violet-500' },
  { name: 'Formación Cívica y Ética', questions: 12, description: 'Derechos, democracia, valores y convivencia ciudadana', color: 'bg-pink-500' },
];

// Fechas ECOEMS 2026
const fechas = [
  { date: '13 feb 2026', title: 'Publicación de convocatoria', description: 'Se publica la convocatoria oficial 2026' },
  { date: '17 mar – 14 abr', title: 'Registro en línea', description: 'Regístrate en el portal oficial y elige hasta 10 opciones de plantel' },
  { date: '18–22 may', title: 'Cierre de registro UNAM/IPN', description: 'Último día para modalidades 2 y 3' },
  { date: 'Junio 2026', title: 'Aplicación del examen', description: 'Fechas: 20, 21, 27 y 28 de junio (UNAM e IPN)' },
  { date: '18 ago 2026', title: 'Resultados', description: 'Publicación de resultados de ingreso' },
];

// Tips de preparación
const tips = [
  { title: 'Planea tu estudio', description: 'Crea un calendario 2-3 meses antes del examen. Dedica tiempo diario a diferentes áreas.' },
  { title: 'Practica con simulacros', description: 'Resuelve exámenes cronometrados con cámara activa para acostumbrarte a las condiciones reales.' },
  { title: 'Identifica tus áreas débiles', description: 'Haz un diagnóstico y enfócate más en las áreas donde tienes menor dominio.' },
  { title: 'Prepara tu espacio', description: 'El examen es desde casa. Asegura un lugar silencioso, con buena luz, computadora con cámara y conexión estable.' },
];

// FAQ data for structured data
const faqItems = [
  { question: '¿Cuándo se aplica el ECOEMS 2026?', answer: 'El registro es del 17 de marzo al 14 de abril de 2026. Las fechas de examen para UNAM e IPN son el 20, 21, 27 y 28 de junio de 2026. Los resultados se publican el 18 de agosto de 2026.' },
  { question: '¿El examen ECOEMS es presencial o en línea?', answer: 'Desde 2025, el ECOEMS es 100% en línea. Lo presentas desde tu casa en una computadora con cámara y micrófono activos. La sesión es supervisada por inteligencia artificial durante las 3 horas del examen.' },
  { question: '¿Todos tienen que presentar el examen ECOEMS?', answer: 'No. Solo aplican examen los aspirantes que eligieron planteles de la UNAM o el IPN y que tienen promedio mínimo de 7.0. Los subsistemas como CBU, CONALEP y DGETI asignan lugares por sorteo.' },
  { question: '¿Qué calificación necesito para pasar el ECOEMS?', answer: 'No hay una calificación mínima para aprobar. La admisión depende de tu puntaje comparado con otros aspirantes y los lugares disponibles en cada plantel. Mientras más alto sea tu puntaje, mejores opciones tendrás.' },
  { question: '¿Puedo usar calculadora en el ECOEMS?', answer: 'No. Solo se permite papel, lápiz y goma. La supervisión con IA detecta objetos como celulares o libros en tu escritorio. Las preguntas de matemáticas están diseñadas para resolverse con operaciones básicas.' },
  { question: '¿Qué pasa si no contesto una pregunta del ECOEMS?', answer: 'Las preguntas sin responder cuentan como incorrectas, pero no restan puntos adicionales. Por eso, siempre es mejor intentar responder todas las preguntas.' },
  { question: '¿Qué necesito para presentar el ECOEMS desde casa?', answer: 'Necesitas una computadora de escritorio o laptop con cámara y micrófono, conexión a internet estable, un espacio bien iluminado y silencioso, y un navegador actualizado como Chrome, Firefox o Edge. No se puede presentar desde celular o tablet.' },
];

const seoTitle = '¿Qué es el ECOEMS? Guía completa 2026 — Fechas, áreas y estructura | TLACU';
const seoDescription = 'Todo sobre el ECOEMS 2026: 128 preguntas, 10 áreas, 3 horas, 100% en línea desde casa. Fechas de registro, estructura del examen, requisitos y consejos de preparación.';
const canonicalUrl = 'https://tlacu.mx/que-es-ecoems';
---

<Layout title={seoTitle} description={seoDescription} ogImage="/images/og/og-que-es-ecoems.png">
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://tlacu.mx/" },
        { "@type": "ListItem", "position": 2, "name": "¿Qué es el ECOEMS?", "item": canonicalUrl }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": seoTitle,
      "description": seoDescription,
      "url": canonicalUrl,
      "inLanguage": "es-MX",
      "isPartOf": { "@type": "WebSite", "name": "TLACU — Prepárate, enciende tu futuro", "url": "https://tlacu.mx/" },
      "about": {
        "@type": "Thing",
        "name": "ECOEMS",
        "description": "Examen de Conocimientos y Habilidades para la Educación Media Superior"
      }
    })} />
  </Fragment>
  <Header />

  <main>
    <!-- Hero -->
    <section class="pt-36 sm:pt-40 pb-20 bg-gradient-hero">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-4xl mx-auto">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-turquoise/20 rounded-full text-turquoise text-sm font-medium mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Guía completa 2026
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
            ¿Qué es el <span class="text-gradient-fire">ECOEMS</span>?
          </h1>
          <p class="text-xl text-white/70 max-w-3xl mx-auto">
            Todo lo que necesitas saber sobre el Examen de Conocimientos y Habilidades para la Educación Media Superior: estructura, áreas, fechas 2026 y cómo prepararte.
          </p>
        </div>
      </div>
    </section>

    <!-- Disclaimer oficial -->
    <section class="py-12 bg-gradient-to-r from-amber-50 via-amber-100/80 to-amber-50 border-y border-amber-200/60">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col md:flex-row items-center gap-6 md:gap-8">
          <div class="w-14 h-14 bg-amber-200/60 rounded-2xl flex items-center justify-center flex-shrink-0">
            <svg class="w-7 h-7 text-amber-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
            </svg>
          </div>
          <div class="text-center md:text-left flex-1">
            <h2 class="text-lg font-black text-amber-900 mb-2">TLACU no tiene relación con el ECOEMS ni con las autoridades educativas</h2>
            <p class="text-amber-800/70 text-sm leading-relaxed">
              TLACU es una plataforma independiente de preparación. No estamos afiliados ni tenemos relación con la SEP, UNAM, IPN ni con el proceso oficial de admisión. La información en esta página es de carácter informativo y puede cambiar sin previo aviso. Para datos oficiales, fechas y registro consulta únicamente el portal oficial.
            </p>
          </div>
          <a href="https://www.miderechomilugar.gob.mx/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-amber-800 text-white font-bold text-sm rounded-xl hover:bg-amber-900 transition-colors whitespace-nowrap flex-shrink-0">
            Ir al sitio oficial
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>

    <!-- Qué es -->
    <section class="py-20 bg-cream">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl sm:text-4xl font-black text-navy mb-6">
              Examen de Conocimientos y Habilidades para la Educación Media Superior
            </h2>
            <p class="text-navy/70 mb-4">
              El <strong class="text-navy">ECOEMS</strong> es el examen oficial de admisión para ingresar a la Educación Media Superior en la Zona Metropolitana del Valle de México. Lo organizan la <strong class="text-navy">SEP, UNAM e IPN</strong>.
            </p>
            <p class="text-navy/70 mb-4">
              Desde 2025, el examen es <strong class="text-navy">100% en línea</strong>: se presenta desde casa, en computadora, con supervisión de cámara e inteligencia artificial. Ya no hay sedes presenciales.
            </p>
            <p class="text-navy/70 mb-6">
              El proceso de registro se hace en el portal oficial
              <a href="https://www.miderechomilugar.gob.mx/" target="_blank" rel="noopener noreferrer" class="text-turquoise font-semibold hover:underline">Mi Derecho Mi Lugar</a>,
              donde eliges hasta 10 opciones de plantel en orden de preferencia. Solo UNAM e IPN aplican examen (requieren promedio mínimo de 7.0). Otros subsistemas como CBU, CONALEP y DGETI asignan lugar por sorteo.
            </p>

            <div class="flex flex-wrap gap-4">
              <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-xl shadow-md">
                <span class="text-2xl">📝</span>
                <div>
                  <div class="text-sm text-navy/60">Preguntas</div>
                  <div class="font-bold text-navy">128</div>
                </div>
              </div>
              <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-xl shadow-md">
                <span class="text-2xl">⏱️</span>
                <div>
                  <div class="text-sm text-navy/60">Duración</div>
                  <div class="font-bold text-navy">3 horas</div>
                </div>
              </div>
              <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-xl shadow-md">
                <span class="text-2xl">📊</span>
                <div>
                  <div class="text-sm text-navy/60">Áreas</div>
                  <div class="font-bold text-navy">10</div>
                </div>
              </div>
              <div class="flex items-center gap-2 px-4 py-2 bg-white rounded-xl shadow-md">
                <span class="text-2xl">🏠</span>
                <div>
                  <div class="text-sm text-navy/60">Modalidad</div>
                  <div class="font-bold text-navy">Desde casa</div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-3xl p-8 shadow-xl border border-navy/5">
            <h3 class="font-bold text-navy mb-6 flex items-center gap-2">
              <span class="w-8 h-8 bg-terracotta/10 rounded-lg flex items-center justify-center text-terracotta">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </span>
              Características del examen
            </h3>
            <ul class="space-y-4">
              {[
                '100% en línea — desde tu casa con computadora',
                'Opción múltiple con 4 respuestas posibles',
                'Supervisión con cámara e IA durante todo el examen',
                'No se penalizan las respuestas incorrectas',
                'Puedes marcar preguntas para revisarlas después',
                'El sistema guarda tu progreso automáticamente',
                'Se envía automáticamente al terminar el tiempo',
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-turquoise mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span class="text-navy/70">{item}</span>
                </li>
              ))}
            </ul>

            <!-- Stats 2025 -->
            <div class="mt-6 pt-5 border-t border-navy/10">
              <div class="text-xs font-bold text-navy/30 uppercase tracking-widest mb-3">Primera edición 2025</div>
              <div class="grid grid-cols-2 gap-3">
                <div class="bg-cream rounded-lg p-2.5 text-center">
                  <div class="text-lg font-black text-navy">109,206</div>
                  <div class="text-[10px] text-navy/40">Registrados</div>
                </div>
                <div class="bg-cream rounded-lg p-2.5 text-center">
                  <div class="text-lg font-black text-navy">98.65%</div>
                  <div class="text-[10px] text-navy/40">Asistencia</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Áreas del examen -->
    <section class="py-20 bg-cream-dark">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-black text-navy mb-4">
            Las 10 áreas del ECOEMS
          </h2>
          <p class="text-navy/60 max-w-2xl mx-auto">
            128 preguntas distribuidas en 10 áreas. Las 4 primeras (Habilidades + Español + Matemáticas) representan el 44% del examen.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-4">
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-sky-500 rounded-xl flex items-center justify-center mb-3">
              <BookOpen class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Habilidad Verbal</h3>
            <p class="text-navy/60 text-xs mb-2">Comprensión lectora, inferencias, ideas principales</p>
            <span class="text-xs font-medium text-navy/40">16 preguntas</span>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-orange-400 rounded-xl flex items-center justify-center mb-3">
              <Binary class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Habilidad Matemática</h3>
            <p class="text-navy/60 text-xs mb-2">Razonamiento lógico, secuencias, analogías</p>
            <span class="text-xs font-medium text-navy/40">16 preguntas</span>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-blue-500 rounded-xl flex items-center justify-center mb-3">
              <Languages class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Español</h3>
            <p class="text-navy/60 text-xs mb-2">Gramática, ortografía, sintaxis</p>
            <span class="text-xs font-medium text-navy/40">12 preguntas</span>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center mb-3">
              <Calculator class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Matemáticas</h3>
            <p class="text-navy/60 text-xs mb-2">Aritmética, álgebra, geometría</p>
            <span class="text-xs font-medium text-navy/40">12 preguntas</span>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-lime-500 rounded-xl flex items-center justify-center mb-3">
              <Dna class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Biología</h3>
            <p class="text-navy/60 text-xs mb-2">Célula, genética, ecosistemas</p>
            <span class="text-xs font-medium text-navy/40">12 preguntas</span>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-slate-500 rounded-xl flex items-center justify-center mb-3">
              <Atom class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Física</h3>
            <p class="text-navy/60 text-xs mb-2">Movimiento, energía, ondas</p>
            <span class="text-xs font-medium text-navy/40">12 preguntas</span>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-fuchsia-500 rounded-xl flex items-center justify-center mb-3">
              <FlaskConical class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Química</h3>
            <p class="text-navy/60 text-xs mb-2">Tabla periódica, reacciones, enlaces</p>
            <span class="text-xs font-medium text-navy/40">12 preguntas</span>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-amber-700 rounded-xl flex items-center justify-center mb-3">
              <Clock class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Historia</h3>
            <p class="text-navy/60 text-xs mb-2">México prehispánico, colonial, moderno</p>
            <span class="text-xs font-medium text-navy/40">12 preguntas</span>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-violet-500 rounded-xl flex items-center justify-center mb-3">
              <Globe2 class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Geografía</h3>
            <p class="text-navy/60 text-xs mb-2">Relieve, climas, regiones de México</p>
            <span class="text-xs font-medium text-navy/40">12 preguntas</span>
          </div>
          <div class="bg-white rounded-2xl p-5 shadow-md border border-navy/5 hover:shadow-lg transition-all">
            <div class="w-12 h-12 bg-pink-500 rounded-xl flex items-center justify-center mb-3">
              <Scale class="w-6 h-6 text-white" />
            </div>
            <h3 class="font-bold text-navy text-sm mb-2">Formación Cívica</h3>
            <p class="text-navy/60 text-xs mb-2">Derechos, democracia, valores</p>
            <span class="text-xs font-medium text-navy/40">12 preguntas</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Proceso y Fechas 2026 -->
    <section class="py-20 bg-gradient-to-br from-navy to-navy-light">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">
            Proceso y fechas ECOEMS 2026
          </h2>
          <p class="text-white/60 max-w-2xl mx-auto">
            El registro y asignación se hacen en el portal oficial
            <a href="https://www.miderechomilugar.gob.mx/" target="_blank" rel="noopener noreferrer" class="text-turquoise hover:underline font-semibold">miderechomilugar.gob.mx</a>
          </p>
        </div>

        <!-- Cómo funciona el proceso -->
        <div class="grid md:grid-cols-3 gap-6 mb-12">
          <div class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/10 text-center">
            <div class="w-12 h-12 bg-terracotta rounded-full flex items-center justify-center text-white font-black text-xl mx-auto mb-4">1</div>
            <h3 class="font-bold text-white mb-2">Regístrate en el portal</h3>
            <p class="text-white/60 text-sm">Crea tu cuenta en Mi Derecho Mi Lugar y elige hasta 10 planteles en orden de preferencia.</p>
          </div>
          <div class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/10 text-center">
            <div class="w-12 h-12 bg-terracotta rounded-full flex items-center justify-center text-white font-black text-xl mx-auto mb-4">2</div>
            <h3 class="font-bold text-white mb-2">Presenta el examen</h3>
            <p class="text-white/60 text-sm">Solo si elegiste UNAM o IPN (promedio mínimo 7.0). Es digital, desde casa, con cámara y supervisión IA.</p>
          </div>
          <div class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/10 text-center">
            <div class="w-12 h-12 bg-terracotta rounded-full flex items-center justify-center text-white font-black text-xl mx-auto mb-4">3</div>
            <h3 class="font-bold text-white mb-2">Recibe tu asignación</h3>
            <p class="text-white/60 text-sm">Basado en tu puntaje y preferencias, se te asigna un plantel. CBU, CONALEP y DGETI asignan por sorteo.</p>
          </div>
        </div>

        <!-- Timeline fechas -->
