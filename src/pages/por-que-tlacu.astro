---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PlatformLink from '../components/PlatformLink.astro';

// Comparación de métodos
const comparisons = [
  {
    feature: 'Exámenes de práctica ilimitados',
    tlacu: true,
    traditional: false,
    generic: 'limited',
    tlacuNote: 'Practica sin límites',
    otherNote: 'Libros con pocas preguntas',
  },
  {
    feature: 'Retroalimentación inmediata',
    tlacu: true,
    traditional: false,
    generic: 'partial',
    tlacuNote: 'Explicación de cada respuesta',
    otherNote: 'Solo respuestas correctas',
  },
  {
    feature: 'Simulador con condiciones reales',
    tlacu: true,
    traditional: false,
    generic: false,
    tlacuNote: 'Cronómetro + cámara',
    otherNote: 'Sin simulación real',
  },
  {
    feature: 'Repetición espaciada (flashcards)',
    tlacu: true,
    traditional: false,
    generic: false,
    tlacuNote: 'Algoritmo SM-2 científico',
    otherNote: 'Memorización manual',
  },
  {
    feature: 'Estadísticas por área',
    tlacu: true,
    traditional: false,
    generic: 'partial',
    tlacuNote: 'Dashboard detallado',
    otherNote: 'Sin seguimiento',
  },
  {
    feature: 'Módulos interactivos',
    tlacu: true,
    traditional: false,
    generic: false,
    tlacuNote: 'Tabla periódica, Célula, Álgebra...',
    otherNote: 'Solo texto e imágenes',
  },
  {
    feature: 'Acceso desde cualquier dispositivo',
    tlacu: true,
    traditional: false,
    generic: true,
    tlacuNote: 'Celular, tablet, computadora',
    otherNote: 'Depende del formato',
  },
  {
    feature: 'Actualización constante',
    tlacu: true,
    traditional: false,
    generic: 'partial',
    tlacuNote: 'Contenido siempre actualizado',
    otherNote: 'Libros desactualizados',
  },
];

// Razones para elegir TLACU
const reasons = [
  {
    icon: '🎯',
    title: 'Enfocado 100% en ECOEMS',
    description: 'No somos una plataforma genérica. Todo nuestro contenido está diseñado específicamente para el formato y temario del ECOEMS.',
  },
  {
    icon: '🧠',
    title: 'Basado en ciencia del aprendizaje',
    description: 'Usamos técnicas probadas como repetición espaciada, práctica activa y retroalimentación inmediata para maximizar la retención.',
  },
  {
    icon: '📊',
    title: 'Datos que guían tu estudio',
    description: 'No estudies a ciegas. Nuestro dashboard te muestra exactamente dónde necesitas mejorar y cuánto has progresado.',
  },
  {
    icon: '🎮',
    title: 'Gamificación que motiva',
    description: 'Rachas, puntos, logros y rankings hacen que estudiar sea menos aburrido y más efectivo.',
  },
  {
    icon: '💰',
    title: 'Precio justo, sin sorpresas',
    description: 'Pago único por 12 meses. Sin suscripciones mensuales, sin cargos ocultos, sin renovaciones automáticas.',
  },
  {
    icon: '👨‍👩‍👧',
    title: 'Panel para Padres y Profesores',
    description: 'Crea cuentas para tus hijos o alumnos, págales Pro y monitorea su progreso desde tu panel.',
  },
  {
    icon: '📱',
    title: 'Diseñado para tu generación',
    description: 'Interfaz rápida, sin distracciones, optimizada para estudiar desde el celular. Estudia donde y cuando quieras.',
  },
];

// Problemas comunes que resuelve TLACU
const problems = [
  {
    problem: '"No sé por dónde empezar a estudiar"',
    solution: 'TLACU te da un camino claro: haz el diagnóstico, identifica tus áreas débiles y enfócate en ellas.',
    icon: '🗺️',
  },
  {
    problem: '"Estudio mucho pero no retengo nada"',
    solution: 'Las flashcards con repetición espaciada te hacen repasar justo cuando estás a punto de olvidar.',
    icon: '🧠',
  },
  {
    problem: '"Me pongo nervioso en los exámenes"',
    solution: 'El simulador con cronómetro y cámara te prepara para las condiciones reales del ECOEMS.',
    icon: '😰',
  },
  {
    problem: '"Los libros de preparación son aburridos"',
    solution: 'Módulos interactivos, gamificación y práctica activa hacen el estudio más dinámico.',
    icon: '😴',
  },
  {
    problem: '"No sé si estoy listo para el examen"',
    solution: 'Las estadísticas detalladas te muestran tu nivel real en cada área del ECOEMS.',
    icon: '❓',
  },
];

const seoTitle = '¿Por qué TLACU? — Compara opciones de preparación ECOEMS | TLACU';
const seoDescription = 'Compara TLACU con otras opciones de preparación para el ECOEMS. Enfoque 100% ECOEMS, ciencia del aprendizaje, módulos interactivos y precio justo.';
const canonicalUrl = 'https://tlacu.mx/por-que-tlacu';
---

<Layout title={seoTitle} description={seoDescription} ogImage="/images/og/og-por-que-tlacu.png">
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": seoTitle,
      "description": seoDescription,
      "url": canonicalUrl,
      "inLanguage": "es-MX",
      "isPartOf": { "@type": "WebSite", "name": "TLACU — Estudia a tu medida", "url": "https://tlacu.mx/" }
    })} />
  </Fragment>
  <Header />

  <main>
    <!-- Hero -->
    <section class="pt-36 sm:pt-40 pb-20 bg-gradient-hero">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center max-w-4xl mx-auto">
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-turquoise/20 rounded-full text-turquoise text-sm font-medium mb-6">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            Compara y decide
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-black text-white leading-tight mb-6">
            ¿Por qué elegir <span class="text-gradient-fire">TLACU</span>?
          </h1>
          <p class="text-xl text-white/70 max-w-3xl mx-auto">
            No todos los métodos de estudio son iguales. Descubre por qué TLACU es la forma más efectiva de prepararte para el ECOEMS.
          </p>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="py-20 bg-cream">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-black text-navy mb-4">
            TLACU vs. métodos tradicionales
          </h2>
          <p class="text-navy/60 max-w-2xl mx-auto">
            Compara las herramientas que ofrece TLACU contra estudiar con libros, apuntes o plataformas genéricas.
          </p>
        </div>

        <!-- Desktop Table -->
        <div class="hidden md:block bg-white rounded-3xl shadow-xl overflow-hidden border border-navy/10">
          <table class="w-full">
            <thead>
              <tr class="bg-navy text-white">
                <th class="py-5 px-6 text-left font-semibold">Característica</th>
                <th class="py-5 px-6 text-center font-semibold">
                  <div class="flex items-center justify-center gap-2">
                    <span class="text-xl">🔥</span>
                    TLACU
                  </div>
                </th>
                <th class="py-5 px-6 text-center font-semibold">Libros / Apuntes</th>
                <th class="py-5 px-6 text-center font-semibold">Plataformas genéricas</th>
              </tr>
            </thead>
            <tbody>
              {comparisons.map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-cream/50'}>
                  <td class="py-4 px-6 font-medium text-navy">{row.feature}</td>
                  <td class="py-4 px-6 text-center">
                    <div class="flex flex-col items-center gap-1">
                      <span class="w-8 h-8 bg-emerald-500/10 rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span class="text-xs text-navy/50">{row.tlacuNote}</span>
                    </div>
                  </td>
                  <td class="py-4 px-6 text-center">
                    <div class="flex flex-col items-center gap-1">
                      <span class="w-8 h-8 bg-red-500/10 rounded-full flex items-center justify-center">
                        <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                      </span>
                      <span class="text-xs text-navy/50">{row.otherNote}</span>
                    </div>
                  </td>
                  <td class="py-4 px-6 text-center">
                    <div class="flex flex-col items-center gap-1">
                      {row.generic === true ? (
                        <span class="w-8 h-8 bg-emerald-500/10 rounded-full flex items-center justify-center">
                          <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                          </svg>
                        </span>
                      ) : row.generic === 'partial' || row.generic === 'limited' ? (
                        <span class="w-8 h-8 bg-amber-500/10 rounded-full flex items-center justify-center">
                          <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                          </svg>
                        </span>
                      ) : (
                        <span class="w-8 h-8 bg-red-500/10 rounded-full flex items-center justify-center">
                          <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                          </svg>
                        </span>
                      )}
                      <span class="text-xs text-navy/50">
                        {row.generic === 'partial' ? 'Parcial' : row.generic === 'limited' ? 'Limitado' : ''}
                      </span>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Mobile Cards -->
        <div class="md:hidden space-y-4">
          {comparisons.map((row) => (
            <div class="bg-white rounded-xl p-5 shadow-md border border-navy/5">
              <h3 class="font-bold text-navy mb-4">{row.feature}</h3>
              <div class="grid grid-cols-3 gap-3 text-center text-sm">
                <div>
                  <div class="w-10 h-10 bg-emerald-500/10 rounded-full flex items-center justify-center mx-auto mb-2">
                    <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                  </div>
                  <div class="font-semibold text-navy">TLACU</div>
                </div>
                <div>
                  <div class="w-10 h-10 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-2">
                    <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                  </div>
                  <div class="text-navy/60">Libros</div>
                </div>
                <div>
                  {row.generic === true ? (
                    <div class="w-10 h-10 bg-emerald-500/10 rounded-full flex items-center justify-center mx-auto mb-2">
                      <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                      </svg>
                    </div>
                  ) : row.generic === 'partial' || row.generic === 'limited' ? (
                    <div class="w-10 h-10 bg-amber-500/10 rounded-full flex items-center justify-center mx-auto mb-2">
                      <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                      </svg>
                    </div>
                  ) : (
                    <div class="w-10 h-10 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-2">
                      <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                      </svg>
                    </div>
                  )}
                  <div class="text-navy/60">Otras</div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Problems & Solutions -->
    <section class="py-20 bg-gradient-to-br from-navy to-navy-light">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-black text-white mb-4">
            ¿Te suena familiar?
          </h2>
          <p class="text-white/60 max-w-2xl mx-auto">
            Problemas comunes que enfrentan los estudiantes y cómo TLACU los resuelve.
          </p>
        </div>

        <div class="space-y-4">
          {problems.map((item) => (
            <div class="bg-white/10 backdrop-blur rounded-2xl p-6 border border-white/10">
              <div class="flex flex-col md:flex-row md:items-center gap-4">
                <div class="flex items-center gap-4 flex-1">
                  <span class="text-4xl">{item.icon}</span>
                  <div>
                    <div class="text-white font-semibold mb-1">{item.problem}</div>
                    <div class="text-white/60 text-sm">Problema común</div>
                  </div>
                </div>
                <div class="hidden md:block text-white/30">
                  <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                  </svg>
                </div>
                <div class="flex items-center gap-4 flex-1 md:pl-4 md:border-l md:border-white/10">
                  <span class="w-10 h-10 bg-emerald-500/20 rounded-full flex items-center justify-center flex-shrink-0">
                    <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                  </span>
                  <div>
                    <div class="text-white/90 text-sm">{item.solution}</div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why TLACU - 6 Reasons -->
    <section class="py-20 bg-cream">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-black text-navy mb-4">
            6 razones para elegir TLACU
          </h2>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {reasons.map((reason) => (
            <div class="bg-white rounded-2xl p-6 shadow-lg border border-navy/5 hover:shadow-xl hover:border-turquoise/30 transition-all">
              <span class="text-4xl mb-4 block">{reason.icon}</span>
              <h3 class="font-bold text-navy text-lg mb-2">{reason.title}</h3>
              <p class="text-navy/60 text-sm">{reason.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Plataforma viva -->
    <section class="py-20 bg-cream">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-gradient-to-br from-navy to-navy-light rounded-3xl p-10 md:p-14 shadow-2xl text-white">
          <div class="grid md:grid-cols-2 gap-10 items-center">
            <div>
              <div class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-500/20 rounded-full text-emerald-400 text-sm font-medium mb-6">
                <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                Plataforma en constante evolución
              </div>
              <h2 class="text-3xl sm:text-4xl font-black leading-tight mb-4">
                Elegir TLACU es elegir algo que <span class="text-turquoise">siempre mejora</span>
              </h2>
              <p class="text-white/70 mb-6">
                El contenido, las preguntas, los módulos y las herramientas de TLACU se revisan y actualizan constantemente. No estás comprando un libro que caduca — estás eligiendo una plataforma viva que crece contigo.
              </p>
              <ul class="space-y-3 mb-8">
                {[
                  'El banco de preguntas crece cada semana',
                  'Las explicaciones se mejoran con base en el uso real',
                  'Nuevas funciones sin costo adicional',
                  'Contenido siempre alineado al ECOEMS actual',
                ].map((item) => (
                  <li class="flex items-center gap-3 text-sm text-white/80">
                    <svg class="w-5 h-5 text-emerald-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
              <a href="/hoja-de-ruta" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-navy font-bold rounded-xl hover:bg-white/90 transition-colors">
                Ver lo que viene en TLACU
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
              </a>
            </div>
            <div class="space-y-3">
              <div class="text-white/40 text-xs font-bold uppercase tracking-widest mb-4">Estado de la plataforma</div>
              {[
                { label: 'Banco de preguntas', estado: 'Creciendo', color: 'text-emerald-400', dot: 'bg-emerald-400' },
                { label: 'Módulos interactivos', estado: 'Expandiendo', color: 'text-amber-400', dot: 'bg-amber-400' },
                { label: 'Plan de estudio personalizado', estado: 'Activo', color: 'text-turquoise', dot: 'bg-turquoise' },
                { label: 'App móvil nativa', estado: 'En desarrollo', color: 'text-white/60', dot: 'bg-white/30' },
                { label: 'Estadísticas avanzadas', estado: 'En desarrollo', color: 'text-white/60', dot: 'bg-white/30' },
              ].map((s) => (
                <div class="flex items-center justify-between bg-white/10 rounded-xl px-4 py-3 border border-white/10">
                  <span class="text-white/90 text-sm">{s.label}</span>
                  <span class={`flex items-center gap-1.5 text-xs font-semibold ${s.color}`}>
                    <span class={`w-1.5 h-1.5 rounded-full ${s.dot}`}></span>
                    {s.estado}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TLACU como complemento -->
    <section class="py-20 bg-cream-dark">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="bg-gradient-to-br from-navy to-navy-light rounded-3xl p-10 md:p-14 shadow-2xl text-white relative overflow-hidden">
          <!-- Decorative element -->
          <div class="absolute top-0 right-0 w-64 h-64 bg-turquoise/10 rounded-full -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
          <div class="absolute bottom-0 left-0 w-40 h-40 bg-terracotta/10 rounded-full translate-y-1/2 -translate-x-1/4 pointer-events-none"></div>

          <div class="relative z-10 grid md:grid-cols-2 gap-10 items-center">
            <div>
              <div class="inline-flex items-center gap-2 px-4 py-2 bg-turquoise/20 rounded-full text-turquoise text-sm font-medium mb-6">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                </svg>
                Complemento ideal
              </div>
              <h2 class="text-3xl sm:text-4xl font-black leading-tight mb-4">
                ¿Ya estudias con otras herramientas? <span class="text-turquoise">TLACU las potencia.</span>
              </h2>
              <p class="text-white/70 text-lg leading-relaxed">
                Tomes clases, uses guías, vayas a academia o tengas tutor &mdash; TLACU encaja en cualquier rutina de estudio y amplifica los resultados. Su formato de práctica activa y retroalimentación inmediata refuerza lo que aprendes en cualquier otro lugar.
              </p>
            </div>
            <div class="space-y-4">
              <div class="bg-white/10 backdrop-blur rounded-2xl p-5 border border-white/10 flex items-start gap-4">
                <span class="text-3xl flex-shrink-0">🏫</span>
                <div>
                  <div class="font-bold text-white mb-1">Academia + TLACU</div>
                  <div class="text-white/60 text-sm">Consolida cada tema visto en clase con preguntas de práctica y flashcards. Lo que aprendes ahí, TLACU lo vuelve permanente.</div>
                </div>
              </div>
              <div class="bg-white/10 backdrop-blur rounded-2xl p-5 border border-white/10 flex items-start gap-4">
                <span class="text-3xl flex-shrink-0">📖</span>
                <div>
                  <div class="font-bold text-white mb-1">Libros y guías + TLACU</div>
                  <div class="text-white/60 text-sm">Lee el concepto en tu guía, luego practica en TLACU. La retroalimentación inmediata cierra la brecha entre leer y entender de verdad.</div>
                </div>
              </div>
              <div class="bg-white/10 backdrop-blur rounded-2xl p-5 border border-white/10 flex items-start gap-4">
                <span class="text-3xl flex-shrink-0">👩‍🏫</span>
                <div>
                  <div class="font-bold text-white mb-1">Tutor + TLACU</div>
                  <div class="text-white/60 text-sm">Las estadísticas de TLACU le muestran a tu tutor exactamente dónde concentrar las sesiones. Menos tiempo perdido, más avance real.</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Traditional vs TLACU Visual -->
