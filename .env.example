# TLACU Landing - Environment Variables
# Copy this to .env.local for local development

# Site URL (used for og:image, sitemap, canonical URLs)
PUBLIC_SITE_URL=https://tlacu.mx

# Platform URL (where users are redirected for login/signup)
PUBLIC_PLATFORM_URL=https://tlacu.mx

# PostHog Analytics
# Note: Events from localhost are automatically disabled
# For dev vs prod separation, use different keys or filter by 'environment' property in PostHog
PUBLIC_POSTHOG_KEY=phc_NscYDrQbAHaee6uYRPgahNErOgleDPvAqqwByaFGvC6
PUBLIC_POSTHOG_HOST=https://t.tlacu.mx

# Resend (contact form email delivery)
# Get your API key at https://resend.com/api-keys
# Domain tlacu.mx must be verified in Resend
RESEND_API_KEY=re_xxxxxxxxxxxx
